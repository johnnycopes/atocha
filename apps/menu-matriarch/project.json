{
  "name": "menu-matriarch",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/menu-matriarch/src",
  "prefix": "app",
  "tags": [
    "scope:menu-matriarch",
    "type:app"
  ],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath.base}"
      ],
      "options": {
        "outputPath": {
          "base": "dist/apps/menu-matriarch",
          "browser": ""
        },
        "index": "apps/menu-matriarch/src/index.html",
        "polyfills": [
          "apps/menu-matriarch/src/polyfills.ts"
        ],
        "tsConfig": "apps/menu-matriarch/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          "apps/menu-matriarch/src/assets"
        ],
        "styles": [
          "apps/menu-matriarch/src/styles.scss"
        ],
        "stylePreprocessorOptions": {
          "includePaths": [
            "apps/menu-matriarch/src/scss"
          ]
        },
        "scripts": [],
        "browser": "apps/menu-matriarch/src/main.ts"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "fileReplacements": [
            {
              "replace": "apps/menu-matriarch/src/environments/environment.ts",
              "with": "apps/menu-matriarch/src/environments/environment.prod.ts"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "options": {
        "port": 4500
      },
      "configurations": {
        "production": {
          "buildTarget": "menu-matriarch:build:production"
        },
        "development": {
          "buildTarget": "menu-matriarch:build:development"
        }
      },
      "defaultConfiguration": "development",
      "continuous": true
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "menu-matriarch:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/apps/menu-matriarch"
      ],
      "options": {
        "jestConfig": "apps/menu-matriarch/jest.config.ts",
        "tsConfig": "apps/menu-matriarch/tsconfig.spec.json"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "parallel": false
      },
      "configurations": {
        "production": {
          "commands": [
            "nx build menu-matriarch",
            "firebase deploy --project=menu-matriarch"
          ]
        },
        "development": {
          "commands": [
            "nx build menu-matriarch --configuration=development",
            "firebase deploy --project=menu-matriarch-dev --only=hosting"
          ]
        }
      },
      "defaultConfiguration": "development"
    },
    "db": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "parallel": false
      },
      "configurations": {
        "reset": {
          "commands": [
            "node ./apps/menu-matriarch/src/firebase/scripts/dev/delete-all-accounts.js"
          ]
        },
        "delete-account": {
          "commands": [
            "node ./apps/menu-matriarch/src/firebase/scripts/dev/delete-account.js"
          ]
        },
        "delete-data": {
          "commands": [
            "node ./apps/menu-matriarch/src/firebase/scripts/dev/delete-data.js"
          ]
        }
      },
      "defaultConfiguration": "reset"
    }
  }
}
