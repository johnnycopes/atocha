{
  "name": "spirit-islander",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/spirit-islander/src",
  "prefix": "app",
  "tags": [
    "scope:spirit-islander",
    "type:app"
  ],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath.base}"
      ],
      "options": {
        "outputPath": {
          "base": "dist/apps/spirit-islander",
          "browser": ""
        },
        "index": "apps/spirit-islander/src/index.html",
        "polyfills": [
          "apps/spirit-islander/src/polyfills.ts"
        ],
        "tsConfig": "apps/spirit-islander/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          "apps/spirit-islander/src/assets"
        ],
        "styles": [
          "apps/spirit-islander/src/styles.scss"
        ],
        "scripts": [],
        "browser": "apps/spirit-islander/src/main.ts"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "fileReplacements": [
            {
              "replace": "apps/spirit-islander/src/environments/environment.ts",
              "with": "apps/spirit-islander/src/environments/environment.prod.ts"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "spirit-islander:build:production"
        },
        "development": {
          "buildTarget": "spirit-islander:build:development"
        }
      },
      "defaultConfiguration": "development",
      "options": {
        "port": 4700
      },
      "continuous": true
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "spirit-islander:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/apps/spirit-islander"
      ],
      "options": {
        "jestConfig": "apps/spirit-islander/jest.config.ts",
        "tsConfig": "apps/spirit-islander/tsconfig.spec.json"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "parallel": false
      },
      "configurations": {
        "production": {
          "commands": [
            "nx build spirit-islander",
            "netlify deploy --prod --auth=${NETLIFY_AUTH_TOKEN} --site=${SPIRIT_ISLANDER_SITE_ID} --filter=spirit-islander --message='Via Nx command'"
          ]
        },
        "development": {
          "commands": [
            "nx build spirit-islander",
            "netlify deploy --auth=${NETLIFY_AUTH_TOKEN} --site=${SPIRIT_ISLANDER_SITE_ID} --filter=spirit-islander --message='Via Nx command'"
          ]
        }
      },
      "defaultConfiguration": "development"
    }
  }
}
